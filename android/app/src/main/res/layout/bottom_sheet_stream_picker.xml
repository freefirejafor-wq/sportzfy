<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet">

    <!-- Handle bar -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_handle"/>

    <!-- Title -->
    <TextView
        android:id="@+id/tvMatchTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:paddingHorizontal="16dp"
        android:paddingBottom="12dp"
        android:text="স্ট্রিম বেছে নিন"/>

    <!-- ── Custom URL button ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:marginHorizontal="16dp"
        android:paddingHorizontal="16dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="10dp"
        android:background="@drawable/bg_btn_watch"
        android:id="@+id/btnAddCustomUrl"
        android:clickable="true"
        android:focusable="true">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🔗  Custom M3U8 / URL যোগ করুন"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/accent"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="＋"
            android:textSize="22sp"
            android:textColor="@color/accent"/>
    </LinearLayout>

    <!-- Category chip group -->
    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chipGroupCategories"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="16dp"
        android:paddingBottom="12dp"/>

    <!-- Stream list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerStreams"
        android:layout_width="match_parent"
        android:layout_height="340dp"
        android:paddingHorizontal="16dp"
        android:clipToPadding="false"/>

    <!-- Cancel -->
    <Button
        android:id="@+id/btnCancel"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginVertical="16dp"
        android:background="@drawable/bg_stream_item"
        android:text="বাতিল"
        android:textColor="@color/text_muted"
        android:textStyle="bold"
        android:stateListAnimator="@null"/>

</LinearLayout>
