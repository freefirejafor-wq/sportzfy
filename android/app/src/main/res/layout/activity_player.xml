<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/player_bg">

    <!-- Video player -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/playerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/player_bg"/>

    <!-- Buffering -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center">

        <ProgressBar
            android:id="@+id/progressBuffering"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:indeterminateTint="@color/accent"
            android:visibility="visible"/>

        <TextView
            android:id="@+id/tvBufferingMsg"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Loading stream…"
            android:textColor="@color/text_muted"
            android:textSize="13sp"
            android:layout_marginTop="8dp"
            android:visibility="visible"/>
    </LinearLayout>

    <!-- TOP BAR -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:background="@drawable/bg_player_gradient_top">

        <!-- Back/Minimize -->
        <TextView
            android:id="@+id/btnBack"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:text="⬇"
            android:textSize="16sp"
            android:textColor="@color/text_primary"
            android:gravity="center"
            android:background="@drawable/bg_player_btn"
            android:layout_marginEnd="10dp"/>

        <!-- Title area -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/tvMatchTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:gravity="center"
                android:maxLines="1"
                android:ellipsize="end"/>

            <TextView
                android:id="@+id/tvStreamName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="@color/accent"
                android:gravity="center"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <!-- Close -->
        <TextView
            android:id="@+id/btnClose"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:text="✕"
            android:textSize="16sp"
            android:textColor="@color/text_primary"
            android:gravity="center"
            android:background="@drawable/bg_player_btn"
            android:layout_marginStart="10dp"/>
    </LinearLayout>

    <!-- CENTER PLAY/PAUSE -->
    <TextView
        android:id="@+id/btnPlayPause"
        android:layout_width="68dp"
        android:layout_height="68dp"
        android:layout_gravity="center"
        android:text="⏸"
        android:textSize="28sp"
        android:textColor="@color/text_primary"
        android:gravity="center"
        android:background="@drawable/bg_play_btn"/>

    <!-- BOTTOM BAR -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingVertical="14dp"
        android:paddingHorizontal="20dp"
        android:background="@drawable/bg_player_gradient_bottom">

        <!-- Streams -->
        <LinearLayout
            android:id="@+id/btnStreams"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="📡" android:textSize="20sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Streams" android:textSize="10sp" android:textStyle="bold" android:textColor="@color/text_muted" android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- Quality -->
        <LinearLayout
            android:id="@+id/btnQuality"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🎯" android:textSize="20sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Quality" android:textSize="10sp" android:textStyle="bold" android:textColor="@color/text_muted" android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- Mini / Float -->
        <LinearLayout
            android:id="@+id/btnFloat"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="📌" android:textSize="20sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Mini" android:textSize="10sp" android:textStyle="bold" android:textColor="@color/text_muted" android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- Lock -->
        <LinearLayout
            android:id="@+id/btnLock"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🔒" android:textSize="20sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Lock" android:textSize="10sp" android:textStyle="bold" android:textColor="@color/text_muted" android:layout_marginTop="4dp"/>
        </LinearLayout>

    </LinearLayout>

    <!-- LOCK OVERLAY -->
    <FrameLayout
        android:id="@+id/lockOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/overlay_light"
        android:visibility="gone">

        <TextView
            android:id="@+id/btnUnlock"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_gravity="center_vertical|end"
            android:layout_marginEnd="20dp"
            android:text="🔓"
            android:textSize="22sp"
            android:gravity="center"
            android:background="@drawable/bg_unlock_btn"/>
    </FrameLayout>

</FrameLayout>
