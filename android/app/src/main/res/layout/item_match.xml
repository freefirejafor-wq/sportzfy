<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="14dp"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="@color/card_bg"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/card_border"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Header: sport · league + status badge -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/tvSport"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/accent"
                android:letterSpacing="0.05"
                android:text="FOOTBALL"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" · "
                android:textColor="@color/text_dim"
                android:textSize="11sp"
                android:layout_marginHorizontal="2dp"/>

            <TextView
                android:id="@+id/tvLeague"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="11sp"
                android:textColor="@color/text_muted"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="FIFA বিশ্বকাপ ২০২৬"/>

            <!-- Status badge -->
            <LinearLayout
                android:id="@+id/statusBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:background="@drawable/bg_badge_upcoming">

                <!-- Live pulsing dot -->
                <View
                    android:id="@+id/liveDot"
                    android:layout_width="6dp"
                    android:layout_height="6dp"
                    android:background="@drawable/bg_live_dot"
                    android:layout_marginEnd="5dp"
                    android:visibility="gone"/>

                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05"
                    android:text="UPCOMING"
                    android:textColor="@color/upcoming_orange"/>
            </LinearLayout>

        </LinearLayout>

        <!-- Teams row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <!-- Home team -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginEnd="8dp">

                <ImageView
                    android:id="@+id/imgHome"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_channel_placeholder"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tvHomeName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:gravity="center"
                    android:maxLines="2"
                    android:ellipsize="end"
                    android:text="Argentina"/>
            </LinearLayout>

            <!-- Score / VS -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:minWidth="80dp"
                android:paddingHorizontal="8dp">

                <TextView
                    android:id="@+id/tvScore"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:gravity="center"
                    android:letterSpacing="0.08"
                    android:text="2  –  1"
                    android:visibility="gone"/>

                <TextView
                    android:id="@+id/tvVs"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_dim"
                    android:gravity="center"
                    android:text="VS"/>

                <TextView
                    android:id="@+id/tvTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="@color/accent"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:layout_marginTop="2dp"
                    android:text="সন্ধ্যা ০৯:০০"/>

            </LinearLayout>

            <!-- Away team -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginStart="8dp">

                <ImageView
                    android:id="@+id/imgAway"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_channel_placeholder"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tvAwayName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:gravity="center"
                    android:maxLines="2"
                    android:ellipsize="end"
                    android:text="France"/>
            </LinearLayout>

        </LinearLayout>

        <!-- HOT badge -->
        <TextView
            android:id="@+id/hotBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔥 HOT"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="@color/upcoming_orange"
            android:paddingHorizontal="8dp"
            android:paddingVertical="3dp"
            android:background="@drawable/bg_badge_hot"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="6dp"
            android:visibility="gone"/>

        <!-- Venue -->
        <TextView
            android:id="@+id/tvVenue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="@color/text_dim"
            android:layout_marginBottom="10dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="📍 Lusail Stadium"
            android:visibility="gone"/>

        <!-- Watch button -->
        <Button
            android:id="@+id/btnWatch"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:background="@drawable/bg_btn_watch"
            android:text="📺  Set Reminder"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:stateListAnimator="@null"/>

    </LinearLayout>

</androidx.cardview.widget.CardView>
