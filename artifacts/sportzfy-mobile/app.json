{
  "expo": {
    "name": "Sportzfy",
    "slug": "sportzfy-mobile",
    "owner": "jafor_1",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/images/sportzfy-icon.png",
    "scheme": "sportzfy",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/images/sportzfy-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0e1a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.sportzfy.app",
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        }
      }
    },
    "android": {
      "package": "com.sportzfy.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/sportzfy-icon.png",
        "backgroundColor": "#0a0e1a"
      },
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE"
      ]
    },
    "web": {
      "favicon": "./assets/images/sportzfy-icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-screen-orientation",
        {
          "initialOrientation": "DEFAULT"
        }
      ],
      [
        "expo-video",
        {
          "supportsBackgroundPlayback": true,
          "supportsPictureInPicture": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "ae63aeca-bab1-4e61-b6a3-b3cb7949e89b"
      }
    }
  }
}
