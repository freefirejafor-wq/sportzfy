<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary">

    <!-- Search bar -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <EditText
            android:id="@+id/searchBar"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:background="@drawable/bg_search"
            android:paddingStart="44dp"
            android:paddingEnd="12dp"
            android:hint="Search matches..."
            android:textColorHint="@color/text_hint"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:inputType="text"
            android:imeOptions="actionSearch"
            android:singleLine="true"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_marginStart="14dp"
            android:text="🔍"
            android:textSize="18sp"/>
    </FrameLayout>

    <!-- Filter chips -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingBottom="10dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/chipLive"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:gravity="center"
            android:text="🔴 LIVE"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/accent"
            android:background="@drawable/bg_chip_active"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:id="@+id/chipUpcoming"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginStart="8dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:gravity="center"
            android:text="⏰ Upcoming"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/text_secondary"
            android:background="@drawable/bg_chip_inactive"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:id="@+id/chipFinished"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginStart="8dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:gravity="center"
            android:text="✅ Finished"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/text_secondary"
            android:background="@drawable/bg_chip_inactive"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

    <!-- Match list -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerMatches"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="8dp"/>

        <LinearLayout
            android:id="@+id/emptyView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📭"
                android:textSize="48sp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="No matches found"
                android:textColor="@color/text_secondary"
                android:textSize="16sp"/>
        </LinearLayout>
    </FrameLayout>

</LinearLayout>
