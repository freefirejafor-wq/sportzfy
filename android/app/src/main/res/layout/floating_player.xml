<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="320dp"
    android:layout_height="180dp"
    android:background="@color/player_bg"
    android:elevation="20dp">

    <!-- Video -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/floatingPlayerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <!-- Teal border -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_floating_border"/>

    <!-- Expand button (top-left) -->
    <ImageButton
        android:id="@+id/btnExpand"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_gravity="top|start"
        android:layout_margin="6dp"
        android:src="@drawable/ic_nav_live"
        android:background="@drawable/bg_floating_btn"
        android:contentDescription="Expand"
        android:padding="6dp"/>

    <!-- Close button (top-right) -->
    <ImageButton
        android:id="@+id/btnFloatClose"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_gravity="top|end"
        android:layout_margin="6dp"
        android:src="@drawable/ic_nav_categories"
        android:background="@drawable/bg_floating_btn"
        android:contentDescription="Close"
        android:padding="6dp"/>

    <!-- Live dot -->
    <View
        android:layout_width="8dp"
        android:layout_height="8dp"
        android:layout_gravity="bottom|start"
        android:layout_margin="8dp"
        android:background="@drawable/bg_live_dot"/>

</FrameLayout>
